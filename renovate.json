{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>projectbluefin/renovate-config"
  ],
  "packageRules": [
    {
      "description": "Automerge digest/pin/patch/minor via GitHub native auto-merge (merge queue handles squash)",
      "matchUpdateTypes": [
        "digest",
        "pin",
        "patch",
        "minor"
      ],
      "automerge": true,
      "platformAutomerge": true
    }
  ]
}
