#!/usr/bin/env bash
set -euo pipefail

pdf="/usr/share/doc/bluefin/bluefin.pdf"
fallback_url="https://docs.projectbluefin.io/"

if [ -f "${pdf}" ]; then
    if flatpak info org.gnome.Papers >/dev/null 2>&1; then
        exec flatpak run org.gnome.Papers "${pdf}"
    fi

    if flatpak info org.gnome.Evince >/dev/null 2>&1; then
        exec flatpak run org.gnome.Evince "${pdf}"
    fi
fi

exec xdg-open "${fallback_url}"
